{
  "tests": [
    {
      "name": "OPTIONS preflight",
      "method": "OPTIONS",
      "path": "/?action=login",
      "expectedStatus": 200
    },
    {
      "name": "Action required",
      "method": "GET",
      "path": "/",
      "expectedStatus": 400,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Login: bad email format",
      "method": "POST",
      "path": "/?action=login",
      "body": {"email": "not-an-email", "password": "Password1"},
      "expectedStatus": 400,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Register: weak password",
      "method": "POST",
      "path": "/?action=register",
      "body": {"email": "test_weak@example.com", "password": "123", "name": "Test"},
      "expectedStatus": 400,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Me without token",
      "method": "GET",
      "path": "/?action=me",
      "expectedStatus": 401,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Verify email: missing token",
      "method": "POST",
      "path": "/?action=verify-email",
      "body": {"token": ""},
      "expectedStatus": 400,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Verify email: invalid token",
      "method": "POST",
      "path": "/?action=verify-email",
      "body": {"token": "abcdefghijklmnopqrstuvwxyz1234567890XYZ"},
      "expectedStatus": 400,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Resend verification without auth",
      "method": "POST",
      "path": "/?action=resend-verification",
      "body": {},
      "expectedStatus": 401,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Security stats without auth",
      "method": "GET",
      "path": "/?action=security-stats",
      "expectedStatus": 401,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Unlock user without auth",
      "method": "POST",
      "path": "/?action=unlock-user",
      "body": {"user_id": 1},
      "expectedStatus": 401,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    }
  ]
}