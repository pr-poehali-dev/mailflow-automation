{
  "tests": [
    {
      "name": "GET keys без авторизации → 401",
      "method": "GET",
      "path": "/?resource=keys",
      "expectedStatus": 401
    },
    {
      "name": "POST keys без авторизации → 401",
      "method": "POST",
      "path": "/?resource=keys",
      "body": {"name": "Тест"},
      "expectedStatus": 401
    },
    {
      "name": "GET contacts без X-API-Key → 401",
      "method": "GET",
      "path": "/?resource=contacts",
      "expectedStatus": 401
    },
    {
      "name": "POST send без X-API-Key → 401",
      "method": "POST",
      "path": "/?resource=send",
      "body": {"to": "x@y.ru", "subject": "t"},
      "expectedStatus": 401
    },
    {
      "name": "GET events без авторизации → 401",
      "method": "GET",
      "path": "/?resource=events",
      "expectedStatus": 401
    },
    {
      "name": "OPTIONS preflight",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    }
  ]
}
